# ============================================================
# DÉDALO · Arquitectura de Protección — dedaloproteccion.mx
# Variables de entorno — copiar a .env.local para desarrollo
# NUNCA incluir valores reales en este archivo
# ============================================================

# ------------------------------------------------------------
# Make / Integromat — Diagnóstico → Notion
# Obtener en: make.com → tu escenario → Webhook → Copy URL
# ------------------------------------------------------------
NEXT_PUBLIC_MAKE_WEBHOOK_URL=

# ------------------------------------------------------------
# Sistema de agenda
# Cal.com: tu username en cal.com (ej. jose-helu)
# ------------------------------------------------------------
NEXT_PUBLIC_CAL_COM_USERNAME=
# Alternativa Calendly:
# NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/tu-usuario

# ------------------------------------------------------------
# Google Analytics 4
# Obtener en: analytics.google.com → Admin → Data Streams → Measurement ID
# Formato: G-XXXXXXXXXX
# ------------------------------------------------------------
NEXT_PUBLIC_GA_MEASUREMENT_ID=
